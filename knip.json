{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/index.ts",
    "src/__tests__/**/*.test.ts",
    "scripts/**/*.{js,ts,mjs}"
  ],
  "ignore": [
    ".adder-pipeline/**",
    ".github/**",
    "scripts/**",
    "stryker.conf.mjs"
  ],
  "ignoreBinaries": [
    "gitleaks",
    "mcpb",
    "semgrep",
    "snyk",
    "sonar-scanner"
  ],
  "ignoreDependencies": [
    "esbuild",
    "glob",
    "postject",
    "ts-morph",
    "tsx"
  ],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
