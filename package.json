{
  "name": "mcp-obsidian-extended",
  "version": "1.0.1",
  "description": "MCP server for Obsidian — 38 tools, 100% REST API coverage",
  "author": "adder-factory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adder-factory/mcp-obsidian-extended.git"
  },
  "homepage": "https://github.com/adder-factory/mcp-obsidian-extended#readme",
  "bugs": {
    "url": "https://github.com/adder-factory/mcp-obsidian-extended/issues"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "model-context-protocol",
    "rest-api",
    "local-rest-api",
    "vault",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "mcp-obsidian-extended": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "tsx scripts/smoke-test.ts",
    "pack:mcpb": "npm run build && npx mcpb pack",
    "sonar": "sonar-scanner -Dsonar.host.url=http://localhost:9000",
    "pr:audit": "bash scripts/pr-audit.sh",
    "verify:all": "npm run build && npm run lint && npm audit && npx knip && npx madge --circular --extensions ts src/",
    "security:all": "npx snyk test && npx snyk code test && npx semgrep --config auto src/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-security": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
